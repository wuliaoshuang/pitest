{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pi-test",
  "version": "0.1.0",
  "identifier": "com.shuang.pi-test",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build && pnpm prepare:pi-runtime",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "pi-test",
        "width": 1120,
        "height": 760,
        "minWidth": 800,
        "minHeight": 600,
        "visible": false,
        "backgroundColor": "#ffffff",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "acceptFirstMouse": true,
        "trafficLightPosition": {
          "x": 18,
          "y": 28
        }
      },
      {
        "label": "splashscreen",
        "title": "Starting PI",
        "url": "/splashscreen.html",
        "width": 720,
        "height": 460,
        "resizable": false,
        "decorations": false,
        "center": true,
        "alwaysOnTop": true,
        "backgroundColor": "#ffffff"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/pi-bundles/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
